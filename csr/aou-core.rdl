        field { sw = r; hw = rw; desc = "Captured RID when an AXI slave RID mismatch occurs. Clears when error clears."; } axi_slv_rid_mismatch_info[11:2];
        field { sw = rw; hw = w; onwrite = woclr; desc = "AXI slave BID mismatch error. Set by HW, write 1 to clear."; } axi_slv_bid_mismatch_err[1:1] = 0;
        field { sw = rw; hw = w; onwrite = woclr; desc = "AXI slave RID mismatch error. Set by HW, write 1 to clear."; } axi_slv_rid_mismatch_err[0:0] = 0;
    } axi_slv_id_mismatch_err_rp2 @ 0x0064;

    // -------------------------------------------------------------------------
    // RP3
    // -------------------------------------------------------------------------
    reg {
        regwidth = 32;
        name = "AXI Split Transaction RP3";
        desc = "Maximum AXI burst lengths for split transactions on Resource Plane 3.";
        field {} reserved_31_16[31:16] = 0;
        field { sw = rw; desc = "Maximum AXI write burst length for split transactions on RP3."; } max_awburstlen[15:8] = 0xF;
        field { sw = rw; desc = "Maximum AXI read burst length for split transactions on RP3."; } max_arburstlen[7:0] = 0xF;
    } axi_split_tr_rp3 @ 0x0068;

    reg {
        regwidth = 32;
        name = "Error Info RP3";
        desc = "Split transaction BID/RID mismatch info and error flags for RP3.";
        field {} reserved_31_22[31:22] = 0;
        field { sw = r; hw = rw; desc = "Captured BID when a split transaction BID mismatch occurs. Clears when error clears."; } split_bid_mismatch_info[21:12];
        field { sw = r; hw = rw; desc = "Captured RID when a split transaction RID mismatch occurs. Clears when error clears."; } split_rid_mismatch_info[11:2];
        field { sw = rw; hw = w; onwrite = woclr; desc = "Split transaction BID mismatch error. Set by HW, write 1 to clear."; } split_bid_mismatch_err[1:1] = 0;
        field { sw = rw; hw = w; onwrite = woclr; desc = "Split transaction RID mismatch error. Set by HW, write 1 to clear."; } split_rid_mismatch_err[0:0] = 0;
    } error_info_rp3 @ 0x006C;

    reg {
        regwidth = 32;
        name = "Write Early Response RP3";
        desc = "Write response done/error status and early BRESP enable for RP3.";
        field {} reserved_31_15[31:15] = 0;
        field { sw = r; hw = w; desc = "Write response completion status for RP3. Read-only, driven by HW."; } write_resp_done[14:14];
        field { sw = rw; hw = w; onwrite = woclr; desc = "Early write response error for RP3. Set by HW, write 1 to clear."; } write_resp_err[13:13] = 0;
        field { sw = r; hw = rw; desc = "Captured BRESP type when early write response error occurs. Clears when error clears."; } write_resp_err_type_info[12:11];
        field { sw = r; hw = rw; desc = "Captured BID when early write response error occurs. Clears when error clears."; } write_resp_err_id_info[10:1];
        field { sw = rw; desc = "Enable early BRESP (write response before data is committed) for RP3."; } early_bresp_en[0:0] = 0;
    } write_early_response_rp3 @ 0x0070;

    reg {
        regwidth = 32;
        name = "AXI Error Info0 RP3";
        desc = "Debug address register (upper) for RP3.";
        field { sw = rw; desc = "Upper 32 bits of the dedicated AXI address used to access R/B response error debug information for RP3. Set this address along with debug_lower_addr and error_info_access_en to enable error information readout by the remote die via AXI read."; } debug_upper_addr[31:0] = 0;
    } axi_error_info0_rp3 @ 0x0074;

    reg {
        regwidth = 32;
        name = "AXI Error Info1 RP3";
        desc = "Debug address register (lower) for RP3.";
        field { sw = rw; desc = "Lower 32 bits of the dedicated AXI address used to access R/B response error debug information for RP3. Together with debug_upper_addr, defines the target address for error information access."; } debug_lower_addr[31:0] = 0;
    } axi_error_info1_rp3 @ 0x0078;

    reg {
        regwidth = 32;
        name = "AXI Slave ID Mismatch Error RP3";
        desc = "AXI slave BID/RID mismatch info and error flags for RP3.";
        field {} reserved_31_22[31:22] = 0;
        field { sw = r; hw = rw; desc = "Captured BID when an AXI slave BID mismatch occurs. Clears when error clears."; } axi_slv_bid_mismatch_info[21:12];
        field { sw = r; hw = rw; desc = "Captured RID when an AXI slave RID mismatch occurs. Clears when error clears."; } axi_slv_rid_mismatch_info[11:2];
        field { sw = rw; hw = w; onwrite = woclr; desc = "AXI slave BID mismatch error. Set by HW, write 1 to clear."; } axi_slv_bid_mismatch_err[1:1] = 0;
        field { sw = rw; hw = w; onwrite = woclr; desc = "AXI slave RID mismatch error. Set by HW, write 1 to clear."; } axi_slv_rid_mismatch_err[0:0] = 0;
    } axi_slv_id_mismatch_err_rp3 @ 0x007C;
};
